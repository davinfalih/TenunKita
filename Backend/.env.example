# ═══════════════════════════════════════════════════════════════════════════════
# E-COMMERCE API - ENVIRONMENT CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# DATABASE CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL="mysql://root:password@localhost:3306/ecommerce_db"

# ─────────────────────────────────────────────────────────────────────────────
# JWT CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRY="7d"

# ─────────────────────────────────────────────────────────────────────────────
# MIDTRANS PAYMENT GATEWAY CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────

# SANDBOX MODE (for development & testing)
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_SERVER_KEY=SB-Mid-server-XXXXXXXXXXXXXXXXXXXXXXX
MIDTRANS_CLIENT_KEY=SB-Mid-client-XXXXXXXXXXXXXXXXXXXXXXX

# PRODUCTION MODE (uncomment when ready for production)
# MIDTRANS_IS_PRODUCTION=true
# MIDTRANS_SERVER_KEY=Mid-server-XXXXXXXXXXXXXXXXXXXXXXX
# MIDTRANS_CLIENT_KEY=Mid-client-XXXXXXXXXXXXXXXXXXXXXXX

# ─────────────────────────────────────────────────────────────────────────────
# CLOUDINARY CONFIGURATION (Optional - untuk image upload)
# ─────────────────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─────────────────────────────────────────────────────────────────────────────
# SERVER CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─────────────────────────────────────────────────────────────────────────────
# WEBHOOK CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────
# Set di Midtrans Dashboard → Settings → HTTP Notification URL
# Contoh: https://yourdomain.com/payments/midtrans/notification
MIDTRANS_WEBHOOK_URL=http://localhost:3000/payments/midtrans/notification

# ─────────────────────────────────────────────────────────────────────────────
# NOTES:
# ─────────────────────────────────────────────────────────────────────────────
# 1. Ganti DATABASE_URL dengan credentials MySQL Anda
# 2. Ganti JWT_SECRET dengan secret key yang strong dan random
# 3. Dapatkan Midtrans keys dari:
#    - Sandbox: https://sandbox.midtrans.com/dashboard
#    - Production: https://dashboard.midtrans.com/dashboard
# 4. Untuk Production, update:
#    - DATABASE_URL ke production database
#    - MIDTRANS_IS_PRODUCTION ke true
#    - MIDTRANS_SERVER_KEY & CLIENT_KEY ke production keys
#    - JWT_SECRET ke strong random string
# 5. JANGAN commit file .env ke repository
